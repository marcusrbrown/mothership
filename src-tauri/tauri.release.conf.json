{
  "$schema": "https://schema.tauri.app/config/2",
  "bundle": {
    "externalBin": ["binaries/ide-server"],
    "targets": ["dmg", "app"],
    "macOS": {
      "entitlements": "Entitlements.plist",
      "hardenedRuntime": true,
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "REPLACE_WITH_GENERATED_TAURI_UPDATER_PUBLIC_KEY",
      "endpoints": [
        "https://github.com/marcusrbrown/mothership/releases/latest/download/latest.json"
      ]
    }
  }
}
