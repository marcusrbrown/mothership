{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mothership",
  "version": "0.1.0",
  "identifier": "com.marcusrbrown.mothership",
  "build": {
    "beforeDevCommand": "bun run ui:dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run ui:build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Mothership",
        "width": 1440,
        "height": 900,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "script-src": "'self'",
        "style-src": "'self' 'unsafe-inline'",
        "img-src": "'self' asset: http://asset.localhost data:",
        "connect-src": "ipc: http://ipc.localhost http://127.0.0.1:* ws://127.0.0.1:*",
        "font-src": "'self'",
        "form-action": "'none'",
        "base-uri": "'self'",
        "object-src": "'none'",
        "frame-ancestors": "'none'"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
