{
  "$schema": "https://schema.tauri.app/config/2",
  "app": {
    "security": {
      "csp": {
        "default-src": "'self'",
        "script-src": "'self'",
        "style-src": "'self' 'unsafe-inline'",
        "img-src": "'self' asset: http://asset.localhost data:",
        "connect-src": "ipc: http://ipc.localhost http://127.0.0.1:* ws://127.0.0.1:* http://localhost:1420 ws://localhost:1421",
        "font-src": "'self'",
        "form-action": "'none'",
        "base-uri": "'self'",
        "object-src": "'none'",
        "frame-ancestors": "'none'"
      }
    }
  }
}
